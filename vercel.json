{
  "trailingSlash": false,
  "buildCommand": "vite build && printf 'export * from \"./entry.mjs\";' > build/server/index.js",
  "outputDirectory": "build/client",
  "framework": null,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "novaranatureestates.com" }],
      "destination": "https://www.novaranatureestates.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://novara-backend-one.vercel.app/api/$1"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [{ "key": "Content-Type", "value": "application/xml" }]
    },
    {
      "source": "/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
    }
  ]
}
